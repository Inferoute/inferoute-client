{
  "info": {
    "name": "Inferoute API",
    "_postman_id": "960e8d06-4874-4fc0-a732-49dbf5dad992",
    "description": "External APIs for Inferoute (via Traefik at http://localhost:80). Use variables: my_bearer_token, X-Internal-Key, base_url (http://localhost:80).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:80" },
    { "key": "my_bearer_token", "value": "" },
    { "key": "X-Internal-Key", "value": "" },
    { "key": "model_name", "value": "Qwen/Qwen2.5-1.5B-Instruct" },
    { "key": "ollama_model_alias", "value": "gguf/qwen3:0.6b" },
    { "key": "vllm_model_alias", "value": "Qwen/Qwen3-0.6B" }
  ],
  "item": [
    {
      "id": "f1-orch-0000000000000001",
      "name": "Orchestrator",
      "description": "Consumer inference (chat/completions). Auth: Bearer token (consumer API key).",
      "item": [
        {
          "id": "r1-chat-compl",
          "name": "Chat Completions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\",\n  \"messages\": [{\"role\": \"user\", \"content\": \"Hello\"}],\n  \"max_tokens\": 100\n}"
            },
            "url": "{{base_url}}/v1/chat/completions",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r2-compl",
          "name": "Completions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\",\n  \"prompt\": \"Hello\",\n  \"max_tokens\": 100\n}"
            },
            "url": "{{base_url}}/v1/completions",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r3-api-chat",
          "name": "API Chat",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\",\n  \"messages\": [{\"role\": \"user\", \"content\": \"Hello\"}],\n  \"max_tokens\": 100\n}"
            },
            "url": "{{base_url}}/api/chat",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r4-api-gen",
          "name": "API Generate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\",\n  \"prompt\": \"Hello\",\n  \"max_tokens\": 100\n}"
            },
            "url": "{{base_url}}/api/generate",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        }
      ]
    },
    {
      "id": "f2-prov-mgmt",
      "name": "Provider Management",
      "description": "Provider model/health/pause/API URL. Auth: Bearer token (provider API key).",
      "item": [
        {
          "id": "r5-add-model",
          "name": "Add Model",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model_name\": \"{{model_name}}\",\n  \"service_type\": \"ollama\",\n  \"input_price_tokens\": 0.0001,\n  \"output_price_tokens\": 0.0002\n}"
            },
            "url": "{{base_url}}/api/provider/models",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r6-list-models",
          "name": "List Models",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/provider/models",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r7-upd-model",
          "name": "Update Model",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model_name\": \"{{model_name}}\",\n  \"service_type\": \"ollama\",\n  \"input_price_tokens\": 0.0001,\n  \"output_price_tokens\": 0.0002\n}"
            },
            "url": "{{base_url}}/api/provider/models/:model_id",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r8-del-model",
          "name": "Delete Model",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/provider/models/:model_id",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r9-push-health",
          "name": "Push Health",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"list\",\n  \"data\": [{\"id\": \"model-1\", \"object\": \"model\", \"created\": 0, \"owned_by\": \"me\"}]\n}"
            },
            "url": "{{base_url}}/api/provider/health",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r10-get-prov-health",
          "name": "Get Provider Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/provider/health",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r11-upd-pause",
          "name": "Update Pause",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"paused\": true\n}" },
            "url": "{{base_url}}/api/provider/pause",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r12-validate-hmac",
          "name": "Validate HMAC",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"hmac\": \"base64_hmac_string\"\n}" },
            "url": "{{base_url}}/api/provider/validate_hmac",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r13-upd-api-url",
          "name": "Update API URL",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"api_url\": \"https://my-provider.example.com/v1\"\n}" },
            "url": "{{base_url}}/api/provider/api_url",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        }
      ]
    },
    {
      "id": "f3-prov-health",
      "name": "Provider Health",
      "description": "Read-only health endpoints. No auth.",
      "item": [
        {
          "id": "r14-get-healthy",
          "name": "Get Healthy Nodes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health/providers/healthy"
          }
        },
        {
          "id": "r15-get-prov-health",
          "name": "Get Provider Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health/provider/:provider_id"
          }
        },
        {
          "id": "r16-filter-prov",
          "name": "Filter Providers",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health/providers/filter?max_cost=0.001&model_name={{model_name}}"
          }
        },
        {
          "id": "r17-filter-user",
          "name": "Filter User Providers",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health/providers/user?user_id=:user_id&model_name={{model_name}}"
          }
        }
      ]
    },
    {
      "id": "f4-cloudflare",
      "name": "Cloudflare",
      "description": "Tunnel request/refresh. Auth: Bearer (provider API key).",
      "item": [
        {
          "id": "r18-req-tunnel",
          "name": "Request Tunnel",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"service_url\": \"http://localhost:11434\"\n}" },
            "url": "{{base_url}}/api/cloudflare/tunnel/request",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r19-refresh-token",
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": true\n}" },
            "url": "{{base_url}}/api/cloudflare/tunnel/refresh-token",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r20-health",
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "id": "f5-model-pricing",
      "name": "Model Pricing",
      "description": "Model prices and pricing data. Auth: Bearer (consumer or provider API key).",
      "item": [
        {
          "id": "r21-get-prices",
          "name": "Get Prices",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"models\": [\"{{model_name}}\", \"gpt-4o\"]\n}"
            },
            "url": "{{base_url}}/api/model-pricing/get-prices",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        },
        {
          "id": "r22-get-pricing-data",
          "name": "Get Pricing Data",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/model-pricing/pricing-data/{{model_name}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{my_bearer_token}}", "type": "string" }] }
          }
        }
      ]
    },
    {
      "id": "f6-ai-apps",
      "name": "AI Applications",
      "description": "Model catalog and approved builds. GET /api/models/approved-builds is public (no auth). Providers use it to look up approved Ollama digests and vLLM hf_revision pins. POST upsert is internal-only (X-Internal-Key; typically from docker network, not host Postman).",
      "item": [
        {
          "id": "r23-get-models",
          "name": "Get Models (OpenAI-style)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/models"
          },
          "description": "Top models by usage in OpenAI-compatible format. No auth."
        },
        {
          "id": "r24-approved-all",
          "name": "List Approved Builds (all)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/models/approved-builds"
          },
          "description": "Public allowlist of verified Ollama + vLLM builds. Use before pulling weights or registering models.\n\nExample use: provider scripts cache this on startup; you can poll it to see which aliases and hf_revision values are live."
        },
        {
          "id": "r25-approved-ollama",
          "name": "List Approved Builds (Ollama)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/models/approved-builds?service_type=ollama",
              "host": ["{{base_url}}"],
              "path": ["api", "models", "approved-builds"],
              "query": [{ "key": "service_type", "value": "ollama" }]
            }
          },
          "description": "Ollama builds only. Each item has alias (e.g. gguf/qwen3:0.6b) and expected_digest from Ollama /api/tags.\n\nWorkflow: ollama pull → compare digest → register alias on your cluster."
        },
        {
          "id": "r26-approved-vllm",
          "name": "List Approved Builds (vLLM)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/models/approved-builds?service_type=vllm",
              "host": ["{{base_url}}"],
              "path": ["api", "models", "approved-builds"],
              "query": [{ "key": "service_type", "value": "vllm" }]
            }
          },
          "description": "vLLM / HuggingFace builds only. Each item has alias, weight_fingerprint, manifest, hf_repo, hf_revision.\n\nWorkflow: hf download at hf_revision → vllm serve with alias as served-model-name → set model_path in provider client."
        },
        {
          "id": "r27-upsert-ollama",
          "name": "Upsert Approved Build (Ollama, internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Internal-Key", "value": "{{X-Internal-Key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alias\": \"{{ollama_model_alias}}\",\n  \"service_type\": \"ollama\",\n  \"expected_digest\": \"7df6b6e09427a769808717c0a93cadc4ae99ed4eb8bf5ca557c90846becea435\",\n  \"min_size_bytes\": 522653767,\n  \"is_active\": true\n}"
            },
            "url": "{{base_url}}/api/models/approved-builds"
          },
          "description": "Platform ops only. Upserts by alias + service_type. Requires X-Internal-Key from internal network.\n\nFrom host Postman this often returns 401 (IP not in docker CIDR). Use inferoute-node/scripts/bootstrap_approved_model.sh --push instead, or curl from api-testing container.\n\nDev key example: set X-Internal-Key collection variable to your development.env value."
        },
        {
          "id": "r28-upsert-vllm",
          "name": "Upsert Approved Build (vLLM, internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Internal-Key", "value": "{{X-Internal-Key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alias\": \"{{vllm_model_alias}}\",\n  \"service_type\": \"vllm\",\n  \"weight_fingerprint\": \"replace-with-bootstrap-output\",\n  \"min_size_bytes\": 1520000000,\n  \"hf_repo\": \"Qwen/Qwen3-0.6B\",\n  \"hf_revision\": \"replace-with-commit-sha\",\n  \"is_active\": true,\n  \"manifest\": [\n    {\n      \"name\": \"config.json\",\n      \"sha256\": \"replace-me\",\n      \"hash_method\": \"full\",\n      \"size\": 1200\n    },\n    {\n      \"name\": \"model.safetensors\",\n      \"sha256\": \"replace-me\",\n      \"hash_method\": \"safetensors_header\",\n      \"size\": 1500000000\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/api/models/approved-builds"
          },
          "description": "Platform ops only. Generate real fingerprint + manifest with inferoute-node bootstrap_approved_model.sh, then POST or use --push.\n\nProviders only need GET; this is for seeding the registry."
        }
      ]
    }
  ]
}
